rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSuperAdmin() {
      return get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.role == 'superadmin';
    }
    
    function getAdminTenantId() {
      return get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.tenantId;
    }

    match /ats_scans/{scanId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isSuperAdmin() ||
        (getAdminTenantId() == resource.data.tenantId)
      );
      allow update, delete: if isSuperAdmin();
    }

    match /admins/{adminId} {
      // THE FIX: Allow anyone logged in to verify partner codes
      allow read: if request.auth != null;
      allow write: if request.auth != null && isSuperAdmin();
    }
  }
}