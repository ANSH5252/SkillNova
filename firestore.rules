rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    function isSuperAdmin() {
      return get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.role == 'superadmin';
    }
    
    function getAdminTenantId() {
      return get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.tenantId;
    }

    // --- ATS SCANS COLLECTION ---
    match /ats_scans/{scanId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isSuperAdmin() ||
        (getAdminTenantId() == resource.data.tenantId)
      );
      allow update, delete: if isSuperAdmin();
    }

    // --- ADMINS COLLECTION ---
    match /admins/{adminId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isSuperAdmin();
    }

    // --- ENTERPRISE STUDENT WHITELIST ---
    match /allowed_students/{emailId} {
      // 1. Students can read their own whitelist document
      // 2. SuperAdmins can read all
      // 3. Partners can read students assigned to their tenantId
      allow read: if request.auth != null && (
        request.auth.token.email == emailId || 
        isSuperAdmin() || 
        (getAdminTenantId() == resource.data.tenantId)
      );
      
      // Only SuperAdmins can add/remove students from the whitelist
      allow write: if request.auth != null && isSuperAdmin();
    }
  
    // --- ENTERPRISE APPLICATIONS ---
    match /partner_applications/{appId} {
      // Anyone on the internet can submit an application
      allow create: if true; 
      // Only the SuperAdmin can read, approve, or delete applications
      allow read, update, delete: if request.auth != null && isSuperAdmin();
    }
    
  } 
} 